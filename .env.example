# 사이트 기본 정보
VITE_SITE_URL=https://test.lib.lc
VITE_SITE_NAME=오늘의 테스트
VITE_CONTACT_EMAIL=

# 카카오톡 공유 (Kakao Developers JavaScript 키). 비워두면 카카오 공유 버튼이 숨겨집니다.
VITE_KAKAO_JAVASCRIPT_KEY=

# Google Analytics 4 측정 ID. 비워두면 분석 스크립트를 로드하지 않습니다.
VITE_GA_MEASUREMENT_ID=

# Google AdSense. ENABLED가 true이고 CLIENT 값이 있을 때만 광고가 표시됩니다.
VITE_ADSENSE_ENABLED=false
VITE_ADSENSE_CLIENT=
# 광고 단위별 슬롯 ID (선택). 비워두면 해당 위치에 광고가 표시되지 않습니다.
VITE_ADSENSE_SLOT_HOME=
VITE_ADSENSE_SLOT_QUESTION=
VITE_ADSENSE_SLOT_RESULT=
VITE_ADSENSE_SLOT_RELATED=
